rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Prescriptions Rules (SRS-81)
    match /prescriptions/{prescriptionId} {
      allow read: if request.auth != null && (
        request.auth.token.role == 'admin' ||
        request.auth.token.role == 'doctor' ||
        resource.data.patientId == request.auth.uid
      );
      allow create, update: if request.auth != null && (
        request.auth.token.role == 'admin' ||
        (request.auth.token.role == 'doctor' && request.auth.uid == request.resource.data.doctorId)
      );
      allow delete: if request.auth != null && request.auth.token.role == 'admin';
    }

    // Chat Rooms Rules (SRS-88)
    match /chat_rooms/{roomId} {
      allow read, write: if request.auth != null && (
        request.auth.uid in resource.data.participants ||
        request.auth.uid in request.resource.data.participants ||
        request.auth.token.role == 'admin'
      );
      
      match /messages/{messageId} {
        allow read, write: if request.auth != null && (
          request.auth.uid in get(/databases/$(database)/documents/chat_rooms/$(roomId)).data.participants ||
          request.auth.token.role == 'admin'
        );
      }
    }
  }
}
