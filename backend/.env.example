# Express Server Port
PORT=3000

# API Secret to secure endpoints from unauthorized access
# Flutter app must send this in the 'x-api-secret' header
API_SECRET=your_super_secret_api_key_here

# Resend API Key for sending emails
RESEND_API_KEY=re_123456789

# Firebase Admin Service Account JSON stringified
# (Needed if not using Render.com native environment configuration)
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"otpta-app",...}
